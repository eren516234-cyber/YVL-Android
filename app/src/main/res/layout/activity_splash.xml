<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splash_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Pulse rings -->
    <View android:id="@+id/ring3" android:layout_width="240dp" android:layout_height="240dp"
        android:layout_gravity="center" android:visibility="invisible"
        android:background="@drawable/bg_ring"/>
    <View android:id="@+id/ring2" android:layout_width="180dp" android:layout_height="180dp"
        android:layout_gravity="center" android:visibility="invisible"
        android:background="@drawable/bg_ring"/>
    <View android:id="@+id/ring1" android:layout_width="140dp" android:layout_height="140dp"
        android:layout_gravity="center" android:visibility="invisible"
        android:background="@drawable/bg_ring"/>

    <LinearLayout
        android:id="@+id/logo_group"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:orientation="vertical"
        android:gravity="center" android:layout_marginBottom="80dp">

        <!-- Vinyl logo -->
        <com.yvl.app.view.VinylLogoView
            android:id="@+id/vinyl_logo"
            android:layout_width="120dp" android:layout_height="120dp"/>

        <!-- YVL -->
        <TextView android:id="@+id/yvl_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="YVL"
            android:textColor="#FFFFFF"
            android:textSize="72sp"
            android:letterSpacing="-0.04"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:visibility="invisible"/>

        <!-- Expand line -->
        <View android:id="@+id/expand_line"
            android:layout_width="80dp" android:layout_height="2dp"
            android:background="#FFFFFF"
            android:layout_marginTop="12dp"
            android:visibility="gone"/>

        <!-- Tagline -->
        <TextView android:id="@+id/tagline"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Music Without Limits"
            android:textColor="#555555"
            android:textSize="16sp"
            android:letterSpacing="0.06"
            android:layout_marginTop="10dp"
            android:visibility="invisible"/>

        <!-- Loading dots -->
        <LinearLayout android:id="@+id/dots_row"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="24dp"
            android:visibility="gone">
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_dot" android:layout_marginEnd="6dp"/>
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_dot" android:layout_marginEnd="6dp"/>
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_dot"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Made by Shourya -->
    <TextView android:id="@+id/credit"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="56dp"
        android:text="Made by Shourya"
        android:textColor="#333333"
        android:textSize="13sp"
        android:letterSpacing="0.08"
        android:fontFamily="sans-serif"
        android:visibility="invisible"/>
</FrameLayout>
