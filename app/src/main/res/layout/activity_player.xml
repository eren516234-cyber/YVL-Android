<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout android:id="@+id/content_panel"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp"
            android:gravity="center_vertical">
            <ImageView android:id="@+id/btn_back"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_back" android:tint="#FFFFFF"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
            <ImageView android:id="@+id/btn_more"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_more" android:tint="#FFFFFF"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <!-- Album Art -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:paddingHorizontal="28dp" android:paddingVertical="8dp">
            <ImageView android:id="@+id/album_art"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_card_dark"/>
            <com.yvl.app.view.VinylView
                android:id="@+id/vinyl_view"
                android:layout_width="match_parent" android:layout_height="match_parent"/>
        </FrameLayout>

        <!-- Bottom card sheet -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bottom_sheet"
            android:paddingTop="20dp" android:paddingBottom="8dp">

            <!-- Song info -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingHorizontal="24dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:id="@+id/song_title_player"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="YVL Music" android:textColor="#FFFFFF"
                        android:textSize="24sp" android:fontFamily="sans-serif-black"
                        android:textStyle="bold" android:letterSpacing="-0.02"
                        android:maxLines="1" android:ellipsize="end"/>
                    <TextView android:id="@+id/song_artist_player"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Artist" android:textColor="#666666"
                        android:textSize="15sp" android:layout_marginTop="3dp"/>
                </LinearLayout>
                <ImageView android:id="@+id/btn_like"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:src="@drawable/ic_heart" android:tint="#FFFFFF"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </LinearLayout>

            <!-- EQ Bars -->
            <com.yvl.app.view.EqBarsView
                android:id="@+id/eq_bars"
                android:layout_width="match_parent" android:layout_height="24dp"
                android:layout_marginHorizontal="24dp" android:layout_marginTop="8dp"/>

            <!-- Seekbar -->
            <SeekBar android:id="@+id/seek_bar"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp" android:layout_marginTop="4dp"
                android:thumb="@drawable/thumb_seekbar"
                android:progressTint="#FFFFFF"
                android:progressBackgroundTint="#333333"
                style="@style/Widget.AppCompat.SeekBar"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingHorizontal="24dp">
                <TextView android:id="@+id/time_current"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0:00" android:textColor="#666666" android:textSize="11sp"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                <TextView android:id="@+id/time_total"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0:00" android:textColor="#666666" android:textSize="11sp"/>
            </LinearLayout>

            <!-- Controls -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="68dp"
                android:orientation="horizontal" android:gravity="center"
                android:paddingHorizontal="20dp" android:layout_marginTop="4dp">
                <ImageView android:id="@+id/btn_shuffle"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:src="@drawable/ic_shuffle" android:tint="#555555"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                <ImageView android:id="@+id/btn_prev"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:src="@drawable/ic_prev" android:tint="#FFFFFF"
                    android:padding="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
                <ImageView android:id="@+id/btn_play_pause"
                    android:layout_width="66dp" android:layout_height="66dp"
                    android:src="@drawable/ic_play"
                    android:background="@drawable/bg_play_btn"
                    android:tint="#000000" android:padding="15dp"
                    android:layout_marginHorizontal="14dp"/>
                <ImageView android:id="@+id/btn_next"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:src="@drawable/ic_next" android:tint="#FFFFFF"
                    android:padding="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                <ImageView android:id="@+id/btn_repeat"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:src="@drawable/ic_repeat" android:tint="#555555"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </LinearLayout>

            <!-- Lyrics / Queue tabs -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                android:orientation="horizontal" android:paddingHorizontal="24dp"
                android:gravity="center_vertical" android:layout_marginTop="4dp">
                <TextView android:id="@+id/tab_lyrics"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Lyrics" android:textColor="#FFFFFF"
                    android:textSize="13sp" android:textStyle="bold"
                    android:paddingEnd="20dp"/>
                <TextView android:id="@+id/tab_queue"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Queue" android:textColor="#555555"
                    android:textSize="13sp" android:textStyle="bold"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                <TextView android:id="@+id/btn_lyrics_style"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Karaoke" android:textColor="#555555"
                    android:textSize="11sp" android:textStyle="bold"
                    android:background="@drawable/bg_card"
                    android:paddingHorizontal="12dp" android:paddingVertical="6dp"/>
            </LinearLayout>

            <!-- Lyrics panel -->
            <LinearLayout android:id="@+id/lyrics_panel"
                android:layout_width="match_parent" android:layout_height="160dp"
                android:orientation="vertical">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/lyrics_rv"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:clipToPadding="false"
                    android:paddingVertical="12dp"/>
                <TextView android:id="@+id/lyrics_empty"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="No lyrics found" android:textColor="#444444"
                    android:textSize="13sp" android:gravity="center"
                    android:visibility="gone"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="24dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
