<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:layout_margin="5dp"
    android:background="@drawable/bg_card">
    <View android:id="@+id/playlist_card"
        android:layout_width="match_parent" android:layout_height="90dp"
        android:background="#1A1A1A"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="10dp" android:background="#111111">
        <TextView android:id="@+id/playlist_name"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>
