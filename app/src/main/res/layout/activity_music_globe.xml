<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">

    <com.yvl.app.view.MusicGlobeView
        android:id="@+id/globe_view"
        android:layout_width="match_parent" android:layout_height="match_parent"/>

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView android:id="@+id/btn_back_globe"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_back" android:tint="#FFFFFF" android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Music Globe" android:textColor="#FFFFFF"
                android:textSize="28sp" android:fontFamily="sans-serif-black"
                android:textStyle="bold" android:layout_marginStart="8dp"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Explore your library in 3D"
            android:textColor="#555555" android:textSize="14sp"
            android:layout_marginTop="4dp" android:layout_marginStart="48dp"/>
    </LinearLayout>

    <!-- Now playing strip at bottom -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="bottom" android:background="#E6111111"
        android:padding="16dp" android:orientation="horizontal" android:gravity="center_vertical">
        <View android:layout_width="44dp" android:layout_height="44dp"
            android:background="@drawable/bg_circle_dark"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Blinding Lights" android:textColor="#FFFFFF"
                android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="The Weeknd" android:textColor="#555555" android:textSize="12sp"/>
        </LinearLayout>
        <ImageView android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_pause" android:tint="#FFFFFF" android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>
</FrameLayout>
