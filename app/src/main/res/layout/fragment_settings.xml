<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:scrollbars="none" android:background="#000000">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="24dp" android:paddingBottom="80dp">

        <View android:layout_width="match_parent" android:layout_height="32dp"/>

        <TextView android:id="@+id/settings_title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Settings" android:textColor="#FFFFFF" android:textSize="40sp"
            android:fontFamily="sans-serif-black" android:textStyle="bold"
            android:letterSpacing="-0.03" android:layout_marginBottom="28dp"/>

        <!-- THEME SECTION -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="THEME" android:textColor="#555555" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.15" android:layout_marginBottom="14dp"/>

        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:scrollbars="none" android:layout_marginBottom="28dp">
            <LinearLayout android:id="@+id/theme_cards_row"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingVertical="8dp"/>
        </HorizontalScrollView>

        <!-- FONT SECTION -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="FONT" android:textColor="#555555" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.15" android:layout_marginBottom="14dp"/>

        <LinearLayout android:id="@+id/fonts_row"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="28dp"/>

        <!-- ABOUT -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:paddingVertical="24dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="YVL" android:textColor="#FFFFFF" android:textSize="26sp"
                android:fontFamily="sans-serif-black" android:textStyle="bold"
                android:letterSpacing="-0.04"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="v4.0 · Made by Shourya"
                android:textColor="#555555" android:textSize="11sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
