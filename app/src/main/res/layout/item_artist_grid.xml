<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="5dp">
    <View android:id="@+id/artist_card"
        android:layout_width="match_parent" android:layout_height="150dp"
        android:background="@drawable/bg_card"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="150dp"
        android:orientation="vertical" android:gravity="bottom">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="#CC000000" android:padding="10dp">
            <TextView android:id="@+id/artist_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
